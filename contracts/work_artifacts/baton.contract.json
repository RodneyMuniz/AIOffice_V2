{
  "artifact_type": "baton",
  "allowed_created_by_roles": [
    "control_kernel",
    "reasoning_assistance",
    "bounded_executor"
  ],
  "required_fields": [
    "baton_summary",
    "resume_objective",
    "resume_authority",
    "resume_context",
    "handoff_notes",
    "blocked_by",
    "next_required_artifacts",
    "qa_attempt_count",
    "qa_retry_ceiling",
    "handoff_state"
  ],
  "optional_fields": [
    "expires_at"
  ],
  "field_types": {
    "baton_summary": "string",
    "resume_objective": "string",
    "resume_authority": "object",
    "resume_context": "object",
    "handoff_notes": "string_array",
    "blocked_by": "string_array",
    "next_required_artifacts": "string_array",
    "expires_at": "nullable_string",
    "qa_attempt_count": "integer",
    "qa_retry_ceiling": "integer",
    "handoff_state": "string"
  },
  "lifecycle": {
    "allowed_statuses": [
      "draft",
      "ready_for_handoff",
      "superseded",
      "closed"
    ],
    "terminal_statuses": [
      "superseded",
      "closed"
    ]
  },
  "allowed_lineage_source_kinds": [
    "execution_bundle",
    "qa_report",
    "manual"
  ],
  "allowed_handoff_states": [
    "follow_up",
    "manual_review"
  ],
  "resume_authority_required_fields": [
    "authority_kind",
    "required_role",
    "checkpoint",
    "resume_allowed",
    "restore_gate_required",
    "notes"
  ],
  "resume_context_required_fields": [
    "prior_execution_bundle_ref",
    "prior_qa_report_ref",
    "baseline_ref",
    "reentry_kind",
    "notes"
  ],
  "allowed_resume_authority_kinds": [
    "operator_controlled"
  ],
  "allowed_resume_roles": [
    "operator"
  ],
  "allowed_resume_checkpoints": [
    "qa_follow_up_ready",
    "manual_review_required"
  ],
  "allowed_resume_reentry_kinds": [
    "retry_entry"
  ],
  "required_qa_retry_ceiling": 4,
  "allowed_orchestration_scopes": [
    "qa_follow_up_only"
  ],
  "allowed_scope_surfaces": [
    "admin_runtime_only",
    "control_kernel",
    "governed_work_objects",
    "planning_records",
    "qa_reports",
    "external_audit_packs",
    "batons"
  ],
  "required_protected_surfaces": [
    "admin_runtime_only",
    "control_kernel",
    "planning_records"
  ],
  "required_prohibited_surfaces": [
    "ui_surfaces",
    "standard_runtime",
    "subproject_runtime",
    "automatic_resume",
    "rollback",
    "broad_orchestration"
  ],
  "minimum_work_object_refs": 1,
  "minimum_planning_record_refs": 1,
  "allowed_work_object_types": [
    "task",
    "bug"
  ],
  "allowed_work_object_relations": [
    "hands_off",
    "blocks"
  ],
  "allowed_planning_record_views": [
    "working",
    "accepted"
  ],
  "allowed_planning_record_relations": [
    "tracks",
    "hands_off"
  ],
  "required_evidence_kinds": [
    "artifact"
  ],
  "status_rules": {
    "ready_for_handoff_requires_next_required_artifacts": true,
    "closed_requires_no_next_required_artifacts": true,
    "manual_review_handoff_requires_retry_ceiling": true
  },
  "forbidden_states": [
    "Ready-for-handoff batons must list the next required artifacts.",
    "Closed batons must not retain unresolved next-required artifacts.",
    "Manual-review batons must reflect retry-ceiling stop behavior rather than an open retry loop.",
    "Batons must capture operator-controlled resume authority and bounded re-entry context before any resume claim is made.",
    "Batons must stay bounded to persistence and load foundations only and must not claim automatic resume or broader recovery behavior.",
    "Batons must remain inside the admin-only bounded follow-up scope and must not imply Standard runtime."
  ]
}
