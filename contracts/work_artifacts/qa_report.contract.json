{
  "artifact_type": "qa_report",
  "allowed_created_by_roles": [
    "control_kernel",
    "reasoning_assistance",
    "bounded_executor"
  ],
  "required_fields": [
    "qa_summary",
    "verdict",
    "checks_run",
    "findings",
    "remediation_required",
    "qa_attempt_count",
    "qa_retry_ceiling",
    "qa_loop_state",
    "next_handoff"
  ],
  "optional_fields": [
    "remediation_notes"
  ],
  "field_types": {
    "qa_summary": "string",
    "verdict": "string",
    "checks_run": "string_array",
    "findings": "string_array",
    "remediation_required": "boolean",
    "remediation_notes": "nullable_string",
    "qa_attempt_count": "integer",
    "qa_retry_ceiling": "integer",
    "qa_loop_state": "string",
    "next_handoff": "string"
  },
  "allowed_verdicts": [
    "pass",
    "fail",
    "blocked"
  ],
  "lifecycle": {
    "allowed_statuses": [
      "draft",
      "review_ready",
      "passed",
      "failed",
      "blocked",
      "retry_exhausted",
      "superseded"
    ],
    "terminal_statuses": [
      "retry_exhausted",
      "superseded"
    ]
  },
  "allowed_qa_loop_states": [
    "closed",
    "retry_required",
    "blocked",
    "retry_exhausted"
  ],
  "allowed_next_handoffs": [
    "none",
    "baton_follow_up",
    "manual_review"
  ],
  "required_qa_retry_ceiling": 4,
  "allowed_lineage_source_kinds": [
    "execution_bundle",
    "manual"
  ],
  "allowed_orchestration_scopes": [
    "bounded_chain_only"
  ],
  "allowed_scope_surfaces": [
    "admin_runtime_only",
    "control_kernel",
    "governed_work_objects",
    "planning_records",
    "execution_bundles",
    "qa_reports"
  ],
  "required_protected_surfaces": [
    "admin_runtime_only",
    "control_kernel",
    "planning_records"
  ],
  "required_prohibited_surfaces": [
    "ui_surfaces",
    "standard_runtime",
    "subproject_runtime",
    "automatic_resume",
    "rollback",
    "broad_orchestration"
  ],
  "minimum_work_object_refs": 1,
  "minimum_planning_record_refs": 1,
  "allowed_work_object_types": [
    "task",
    "bug"
  ],
  "allowed_work_object_relations": [
    "verifies",
    "found_in"
  ],
  "allowed_planning_record_views": [
    "working",
    "accepted"
  ],
  "allowed_planning_record_relations": [
    "tracks"
  ],
  "required_evidence_kinds": [
    "test_output"
  ],
  "status_rules": {
    "passed_requires_remediation_false": true,
    "failed_requires_remediation_true": true,
    "failed_requires_remediation_notes": true,
    "blocked_requires_blocked_verdict": true,
    "retry_exhausted_requires_manual_review": true
  },
  "forbidden_states": [
    "Passed QA Reports must not require remediation.",
    "Failed QA Reports must record remediation notes.",
    "Retry-exhausted QA Reports must require manual review handoff and must not continue the bounded retry loop.",
    "QA Reports must stay bounded to explicit QA outcomes and remediation state.",
    "QA Reports must remain inside the admin-only bounded chain and must not imply Standard runtime."
  ]
}
