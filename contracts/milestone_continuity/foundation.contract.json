  ],
  "allowed_handoff_next_actions": [
    "operator_review_required",
    "manual_repo_state_review_required"
  ],
  "allowed_resume_execution_claims": [
    "not_implied"
  ],
  "required_authoritative_ref_fields": [
    "readme_path",
    "active_state_path",
    "kanban_path",
    "decision_log_path",
    "milestone_authority_path"
  ]
