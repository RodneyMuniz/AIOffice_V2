  "rules": [
    "schema_only_qa_is_not_meaningful_qa",
    "narrative_only_qa_is_not_evidence",
    "passed_aggregate_verdict_requires_no_unresolved_blocking_issues",
    "queued_stage_requires_fix_queue_ref",
    "fix_executed_stage_requires_fix_execution_ref",
    "rerun_stage_requires_rerun_ref",
    "compared_stage_requires_rerun_ref_and_before_after_comparison_ref",
    "signed_off_stage_requires_fix_queue_fix_execution_rerun_comparison_external_replay_operator_summary_and_signoff_refs",
    "signed_off_stage_requires_external_replay_scope_external",
    "signed_off_stage_requires_operator_summary_ref",
    "executor_self_certification_cannot_be_qa_authority",
    "local_only_evidence_cannot_be_external_replay_proof",
    "successor_milestone_opening_claims_are_rejected"
