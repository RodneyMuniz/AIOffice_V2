  "allowed_issue_statuses": [
    "detected",
    "classified",
    "queued",
    "authorized",
    "fixed",
    "resolved",
    "unresolved",
    "wont_fix"
  ],
  "required_non_claims": [
    "no R13 hard value gate delivered by R13-002",
    "no meaningful QA loop gate delivered yet",
    "no detector implementation delivered by R13-002",
    "no fix queue execution delivered by R13-002",
    "no bounded fix execution delivered by R13-002",
    "no external replay proof delivered by R13-002",
    "no current operator control-room delivered by R13-002",
    "no final QA signoff delivered by R13-002",
    "no real production QA",
    "no executor self-certification as QA",
    "no R14 or successor opening"
