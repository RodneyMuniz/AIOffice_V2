{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/work-order.schema.json",
  "title": "WorkOrder",
  "type": "object",
  "required": [
    "id",
    "card_id",
    "title",
    "summary",
    "status",
    "requested_by_agent_id",
    "assigned_agent_id",
    "approval_required"
  ],
  "properties": {
    "id": { "type": "string" },
    "card_id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "running",
        "waiting_approval",
        "approved",
        "rejected",
        "completed",
        "blocked",
        "cancelled"
      ]
    },
    "requested_by_agent_id": { "type": "string" },
    "assigned_agent_id": { "type": "string" },
    "approval_required": { "type": "boolean" },
    "request_requires_approval": { "type": "boolean" },
    "handoff_target_agent_id": { "type": "string" },
    "source_work_order_id": { "type": "string" },
    "qa_result_id": { "type": "string" },
    "repair_request_id": { "type": "string" },
    "iteration_number": { "type": "integer", "minimum": 1 },
    "work_order_type": { "type": "string", "enum": ["original", "repair"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
