{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/status-response.schema.json",
  "title": "StatusResponse",
  "type": "object",
  "required": [
    "product_name",
    "milestone",
    "repo",
    "branch",
    "posture",
    "r18_posture",
    "current_card_id",
    "current_work_order_id",
    "current_agent_id",
    "cards_count",
    "work_orders_count",
    "approvals_count",
    "pending_approvals_count",
    "handoffs_count",
    "pending_handoffs_count",
    "qa_results_count",
    "failed_qa_results_count",
    "blocked_qa_results_count",
    "repair_requests_count",
    "open_repair_requests_count",
    "completed_repair_requests_count",
    "workflow_iterations_count",
    "repair_qa_handoffs_count",
    "repair_qa_results_count",
    "events_count",
    "evidence_count",
    "allowed_card_statuses",
    "allowed_work_order_statuses",
    "non_claims"
  ],
  "properties": {
    "product_name": { "type": "string" },
    "milestone": { "type": "string" },
    "repo": { "type": "string" },
    "branch": { "type": "string" },
    "posture": { "type": "string" },
    "r18_posture": { "type": "string" },
    "current_card_id": { "type": ["string", "null"] },
    "current_work_order_id": { "type": ["string", "null"] },
    "current_agent_id": { "type": ["string", "null"] },
    "cards_count": { "type": "integer", "minimum": 0 },
    "work_orders_count": { "type": "integer", "minimum": 0 },
    "approvals_count": { "type": "integer", "minimum": 0 },
    "pending_approvals_count": { "type": "integer", "minimum": 0 },
    "handoffs_count": { "type": "integer", "minimum": 0 },
    "pending_handoffs_count": { "type": "integer", "minimum": 0 },
    "qa_results_count": { "type": "integer", "minimum": 0 },
    "failed_qa_results_count": { "type": "integer", "minimum": 0 },
    "blocked_qa_results_count": { "type": "integer", "minimum": 0 },
    "repair_requests_count": { "type": "integer", "minimum": 0 },
    "open_repair_requests_count": { "type": "integer", "minimum": 0 },
    "completed_repair_requests_count": { "type": "integer", "minimum": 0 },
    "workflow_iterations_count": { "type": "integer", "minimum": 0 },
    "repair_qa_handoffs_count": { "type": "integer", "minimum": 0 },
    "repair_qa_results_count": { "type": "integer", "minimum": 0 },
    "events_count": { "type": "integer", "minimum": 0 },
    "evidence_count": { "type": "integer", "minimum": 0 },
    "allowed_card_statuses": {
      "type": "array",
      "items": { "type": "string", "enum": ["intake", "planned", "in_progress", "blocked", "done", "archived"] }
    },
    "allowed_work_order_statuses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "draft",
          "ready",
          "running",
          "waiting_approval",
          "approved",
          "rejected",
          "completed",
          "blocked",
          "cancelled"
        ]
      }
    },
    "non_claims": { "type": "array", "items": { "type": "string" } }
  }
}
