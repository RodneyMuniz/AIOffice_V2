{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/audit-acknowledgement.schema.json",
  "title": "AuditAcknowledgement",
  "type": "object",
  "required": [
    "id",
    "exception_id",
    "exception_source_ref",
    "exception_type",
    "status",
    "reason",
    "acknowledged_by",
    "created_at",
    "updated_at",
    "resolved_at",
    "evidence_refs"
  ],
  "properties": {
    "id": { "type": "string" },
    "exception_id": { "type": "string" },
    "exception_source_ref": { "type": "string" },
    "exception_type": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["acknowledged", "resolved", "dismissed"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "acknowledged_by": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "resolved_at": { "type": ["string", "null"] },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "examples": [
    {
      "id": "R19-AUDIT-ACK-001",
      "exception_id": "audit-policy-override-R19-POLICY-OVERRIDE-001",
      "exception_source_ref": "runtime/state/policy_overrides.json#R19-POLICY-OVERRIDE-001",
      "exception_type": "policy_override",
      "status": "acknowledged",
      "reason": "Reviewed and accepted as intentional.",
      "acknowledged_by": "operator",
      "created_at": "2026-05-14T00:00:00Z",
      "updated_at": "2026-05-14T00:00:00Z",
      "resolved_at": null,
      "evidence_refs": [
        "runtime/state/policy_overrides.json#R19-POLICY-OVERRIDE-001",
        "runtime/state/audit_acknowledgements.json#R19-AUDIT-ACK-001"
      ]
    }
  ]
}
