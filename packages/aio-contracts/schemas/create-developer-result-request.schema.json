{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/create-developer-result-request.schema.json",
  "title": "CreateDeveloperResultRequest",
  "type": "object",
  "required": ["result_type", "summary", "changed_paths", "notes", "agent_id"],
  "properties": {
    "result_type": {
      "type": "string",
      "enum": ["implementation", "repair", "documentation", "validation", "other"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "agent_id": { "type": "string", "minLength": 1 }
  },
  "examples": [
    {
      "result_type": "implementation",
      "summary": "Implementation summary",
      "changed_paths": ["apps/operator-ui/src/App.tsx"],
      "notes": "Additional notes",
      "agent_id": "developer_codex"
    }
  ]
}
