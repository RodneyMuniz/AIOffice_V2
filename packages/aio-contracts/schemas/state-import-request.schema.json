{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/state-import-request.schema.json",
  "title": "StateImportRequest",
  "type": "object",
  "required": ["collections", "import_reason"],
  "properties": {
    "collections": {
      "description": "Object keyed by known collection name, or the collection array from GET /state/export.",
      "oneOf": [
        { "type": "object", "additionalProperties": true },
        { "type": "array", "items": { "type": "object" } }
      ]
    },
    "import_reason": { "type": "string", "minLength": 1 },
    "requested_by": { "type": "string" }
  },
  "examples": [
    {
      "collections": {
        "cards": [{ "id": "R19-CARD-001", "title": "Restored card" }],
        "work_orders": [{ "id": "R19-WO-001", "card_id": "R19-CARD-001" }]
      },
      "import_reason": "Restoring local demo state",
      "requested_by": "operator"
    }
  ]
}
