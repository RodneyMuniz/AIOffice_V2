{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/audit-acknowledgement-history-entry.schema.json",
  "title": "AuditAcknowledgementHistoryEntry",
  "type": "object",
  "required": [
    "id",
    "acknowledgement_id",
    "exception_id",
    "exception_source_ref",
    "exception_type",
    "previous_status",
    "new_status",
    "reason",
    "changed_by",
    "changed_at",
    "evidence_refs"
  ],
  "properties": {
    "id": { "type": "string" },
    "acknowledgement_id": { "type": "string" },
    "exception_id": { "type": "string" },
    "exception_source_ref": { "type": "string" },
    "exception_type": { "type": "string" },
    "previous_status": {
      "type": ["string", "null"],
      "enum": ["acknowledged", "resolved", "dismissed", null]
    },
    "new_status": {
      "type": "string",
      "enum": ["acknowledged", "resolved", "dismissed"]
    },
    "reason": { "type": "string", "minLength": 1 },
    "changed_by": { "type": "string" },
    "changed_at": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "examples": [
    {
      "id": "R19-AUDIT-ACK-HISTORY-001",
      "acknowledgement_id": "R19-AUDIT-ACK-001",
      "exception_id": "audit-policy-override-R19-POLICY-OVERRIDE-001",
      "exception_source_ref": "runtime/state/policy_overrides.json#R19-POLICY-OVERRIDE-001",
      "exception_type": "policy_override",
      "previous_status": null,
      "new_status": "acknowledged",
      "reason": "Reviewed and accepted as intentional.",
      "changed_by": "operator",
      "changed_at": "2026-05-14T00:05:00Z",
      "evidence_refs": [
        "runtime/state/policy_overrides.json#R19-POLICY-OVERRIDE-001",
        "runtime/state/audit_acknowledgements.json#R19-AUDIT-ACK-001",
        "runtime/state/audit_acknowledgement_history.json#R19-AUDIT-ACK-HISTORY-001"
      ]
    }
  ]
}
