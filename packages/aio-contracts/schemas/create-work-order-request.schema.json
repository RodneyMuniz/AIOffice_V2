{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/create-work-order-request.schema.json",
  "title": "CreateWorkOrderRequest",
  "type": "object",
  "required": ["card_id", "title", "description", "assigned_agent_id", "request_requires_approval"],
  "properties": {
    "card_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "assigned_agent_id": { "type": "string" },
    "request_requires_approval": { "type": "boolean" },
    "source_work_order_id": { "type": "string" },
    "qa_result_id": { "type": "string" },
    "repair_request_id": { "type": "string" },
    "iteration_number": { "type": "integer", "minimum": 1 },
    "work_order_type": { "type": "string", "enum": ["original", "repair"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" } }
  }
}
