{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/handoff.schema.json",
  "title": "Handoff",
  "type": "object",
  "required": [
    "id",
    "source_agent_id",
    "target_agent_id",
    "source_role",
    "target_role",
    "card_id",
    "work_order_id",
    "title",
    "summary",
    "status",
    "payload_summary",
    "validation_summary",
    "created_at",
    "updated_at",
    "decided_at",
    "decision_reason",
    "evidence_refs"
  ],
  "properties": {
    "id": { "type": "string" },
    "source_agent_id": { "type": "string" },
    "target_agent_id": { "type": "string" },
    "source_role": { "type": "string" },
    "target_role": { "type": "string" },
    "card_id": { "type": "string" },
    "work_order_id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "status": { "type": "string", "enum": ["proposed", "accepted", "rejected", "completed", "blocked"] },
    "payload_summary": { "type": "string" },
    "validation_summary": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "decided_at": { "type": ["string", "null"] },
    "decision_reason": { "type": ["string", "null"] },
    "repair_request_id": { "type": "string" },
    "qa_result_id": { "type": "string" },
    "iteration_number": { "type": "integer", "minimum": 1 },
    "handoff_purpose": { "type": "string", "enum": ["initial_qa", "repair_qa"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" } }
  },
  "examples": [
    {
      "id": "R19-HANDOFF-001",
      "source_agent_id": "developer_codex",
      "target_agent_id": "qa_test",
      "source_role": "Developer/Codex",
      "target_role": "QA/Test",
      "card_id": "R19-CARD-001",
      "work_order_id": "R19-WO-001",
      "title": "QA handoff for R19-WO-001",
      "summary": "Developer/Codex requests QA/Test validation.",
      "status": "proposed",
      "payload_summary": "Work order is ready for a local QA pass.",
      "validation_summary": "References validated by the API; no autonomous agent was invoked.",
      "created_at": "2026-05-13T00:00:00Z",
      "updated_at": "2026-05-13T00:00:00Z",
      "decided_at": null,
      "decision_reason": null,
      "iteration_number": 1,
      "handoff_purpose": "initial_qa",
      "evidence_refs": ["runtime/state/handoffs.json#R19-HANDOFF-001"]
    },
    {
      "id": "R19-HANDOFF-002",
      "source_agent_id": "developer_codex",
      "target_agent_id": "qa_test",
      "source_role": "Developer/Codex",
      "target_role": "QA/Test",
      "card_id": "R19-CARD-001",
      "work_order_id": "R19-WO-002",
      "title": "Repair QA handoff for R19-WO-002",
      "summary": "Developer/Codex requests QA/Test validation for repair iteration 2.",
      "status": "proposed",
      "payload_summary": "Repair work order is ready for QA.",
      "validation_summary": "Repair request, source QA result, card, and repair work-order linkage were validated.",
      "created_at": "2026-05-13T00:10:00Z",
      "updated_at": "2026-05-13T00:10:00Z",
      "decided_at": null,
      "decision_reason": null,
      "repair_request_id": "R19-REPAIR-001",
      "qa_result_id": "R19-QA-RESULT-001",
      "iteration_number": 2,
      "handoff_purpose": "repair_qa",
      "evidence_refs": ["runtime/state/handoffs.json#R19-HANDOFF-002"]
    }
  ]
}
