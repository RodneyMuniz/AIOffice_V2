{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aioffice.local/contracts/repair-request-decision.schema.json",
  "title": "RepairRequestDecision",
  "type": "object",
  "required": ["decision_reason", "decided_by"],
  "properties": {
    "decision_reason": { "type": "string" },
    "decided_by": { "type": "string", "minLength": 1 }
